# CRAFT-ON web — example environment. Copy to `.env.local` for dev.
# Real `.env*` files are gitignored.

# Base URL of the crafton-api backend.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Auth mode: "fake" (dev/CI/E2E — phone+OTP simulated, token matches the API's
# fake verifier) or "firebase" (real phone OTP).
NEXT_PUBLIC_AUTH_MODE=fake

# Firebase web config (only needed when NEXT_PUBLIC_AUTH_MODE=firebase).
# NEXT_PUBLIC_FIREBASE_API_KEY=
# NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
# NEXT_PUBLIC_FIREBASE_PROJECT_ID=crafton-dev-500709
