{
  "name": "crafton-web",
  "version": "0.1.0",
  "private": true,
  "description": "CRAFT-ON web/PWA frontend (workers + contractors + admin).",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "i18n:check": "node scripts/check-i18n-parity.mjs",
    "gen:api": "openapi-typescript openapi.snapshot.json -o src/lib/api/schema.ts",
    "e2e": "playwright test"
  },
  "dependencies": {
    "next": "15.1.6",
    "next-intl": "3.26.3",
    "react": "19.0.0",
    "react-dom": "19.0.0"
  },
  "devDependencies": {
    "@playwright/test": "1.49.1",
    "@testing-library/jest-dom": "6.6.3",
    "@testing-library/react": "16.1.0",
    "@types/node": "22.10.5",
    "@types/react": "19.0.7",
    "@types/react-dom": "19.0.3",
    "@vitejs/plugin-react": "4.3.4",
    "autoprefixer": "10.4.20",
    "eslint": "9.18.0",
    "eslint-config-next": "15.1.6",
    "jsdom": "25.0.1",
    "openapi-typescript": "7.5.2",
    "postcss": "8.4.49",
    "tailwindcss": "3.4.17",
    "typescript": "5.7.3",
    "vitest": "2.1.8"
  }
}
